# Discord
DISCORD_TOKEN=
DEV_DISCORD_TOKEN=
# BOT_ENV=dev  # dev-режим: бот берёт DEV_DISCORD_TOKEN вместо DISCORD_TOKEN

# Вебхук уведомлений о падении systemd-сервиса (notify_failure.py на VDS)
FAILURE_WEBHOOK_URL=

# Ключи LLM-вендоров: имена соответствуют vendors[].env в data/ai_settings.yaml
GEMINI=
GROQ=
OR=
GHM=
DS=

# Веб-поиск ИИ: свой SearXNG-инстанс (опционально — без него используется ddgs).
# В settings.yml инстанса должно быть search.formats: [html, json]
# SEARXNG_URL=http://127.0.0.1:8888

# RCON Minecraft-сервера (опционально — без него /rcon-команды недоступны)
# RCON_HOST=
# RCON_PORT=25575
# RCON_PASSWORD=
